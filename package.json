{
  "name": "@lsp-mux/vscode-eslint-lsp",
  "version": "3.0.24",
  "description": "ESLint language server extracted from the VS Code ESLint extension",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lsp-mux/vscode-eslint-lsp.git"
  },
  "bugs": {
    "url": "https://github.com/lsp-mux/vscode-eslint-lsp/issues"
  },
  "homepage": "https://github.com/lsp-mux/vscode-eslint-lsp#readme",
  "type": "module",
  "main": "dist/source/main.js",
  "publishConfig": {
    "directory": "dist/source",
    "main": "main.js"
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "build": "pnpm run extract && pnpm run prepare-publish && pnpm run pack && pnpm run test:e2e",
    "extract": "node --experimental-strip-types scripts/extract.ts",
    "pack": "node --experimental-strip-types scripts/pack.ts",
    "prepare-publish": "node --experimental-strip-types scripts/prepare-publish.ts",
    "publish": "node --experimental-strip-types scripts/publish.ts",
    "release": "node --experimental-strip-types scripts/release.ts",
    "test:e2e": "vitest run --config vitest.config.e2e.ts"
  },
  "devDependencies": {
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "22.16.0",
    "@types/yauzl": "2.10.3",
    "vitest": "4.1.2",
    "yauzl": "3.2.1"
  }
}
